---
import { header } from "../../../data/navigation.json";
---

<header class="bg-white">
  <div class="mx-auto max-w-6xl px-8">
    <nav class="flex items-center justify-between py-4">
      <a href={header.logo_url}>
        <img class="w-48" src={header.logo} alt={header.logo_alt_text} />
      </a>

      <ul class="hidden sm:flex items-center gap-6">
        {header.links.map((link) => (
          <li>
            <a class="text-gray-700 hover:text-gray-500 transition-colors" href={link.link}>
              {link.text}
            </a>
          </li>
        ))}
      </ul>

      <button
        class="sm:hidden p-2"
        aria-label="Open navigation menu"
        popovertarget="mobile-menu"
        popovertargetaction="show"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <div popover id="mobile-menu" class="fixed inset-0 bg-white p-8 z-50">
        <button
          class="absolute top-4 right-4 p-2"
          aria-label="Close navigation menu"
          popovertarget="mobile-menu"
          popovertargetaction="hide"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <ul class="flex flex-col items-center gap-6 pt-16">
          {header.links.map((link) => (
            <li>
              <a class="text-lg text-gray-700 hover:text-gray-500" href={link.link}>
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>
</header>
